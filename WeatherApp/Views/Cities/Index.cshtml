@model CityWeatherViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    ViewData["Description"] = Model.MetaDescription;
    ViewData["Keywords"] = Model.MetaKeywords;
    ViewData["Canonical"] = Model.CanonicalUrl;
    
    var temperature = Model.WeatherData?.Temperature ?? 0;
    var tempColor = temperature > 30 ? "#ff6b6b" : (temperature > 20 ? "#feca57" : (temperature > 10 ? "#54a0ff" : "#5f27cd"));

    var inv = System.Globalization.CultureInfo.InvariantCulture;
    var w = Model.WeatherData;
}

@section Head {
    @if (w != null)
    {
        <!-- Place + Weather structured data for this city (helps rank "weather in @Model.CityName") -->
        <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "Place",
          "name": "@Html.Raw(Model.CityName.Replace("\"", "\\\""))",
          "url": "@Model.CanonicalUrl",
          "geo": {
            "@@type": "GeoCoordinates",
            "latitude": @w.Latitude.ToString("0.####", inv),
            "longitude": @w.Longitude.ToString("0.####", inv)
          },
          "description": "Current weather in @Html.Raw(Model.CityName.Replace("\"", "\\\"")): @Html.Raw((w.Description ?? "").Replace("\"", "\\\"")), @w.Temperature.ToString("0", inv)°C, humidity @w.Humidity%, wind @w.WindSpeed.ToString("0.#", inv) m/s."
        }
        </script>
    }

    <!-- Breadcrumb Schema -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "BreadcrumbList",
      "itemListElement": [
        { "@@type": "ListItem", "position": 1, "name": "Home", "item": "https://kairosweather.info/" },
        { "@@type": "ListItem", "position": 2, "name": "@Html.Raw(Model.CityName.Replace("\"", "\\\"")) Weather", "item": "@Model.CanonicalUrl" }
      ]
    }
    </script>
}

<!-- Dark Mode Toggle -->
<div class="theme-toggle">
    <button class="theme-btn" id="themeToggle" onclick="toggleTheme()">
        <i class="fas fa-moon" id="themeIcon"></i>
    </button>
</div>

<!-- Modern Breadcrumb -->
<nav class="modern-breadcrumb" aria-label="breadcrumb">
    <div class="container">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="fas fa-home"></i> <span data-i18n="Home">Home</span></a></li>
            <li class="breadcrumb-item"><a href="/weather" data-i18n="Weather">Weather</a></li>
            <li class="breadcrumb-item active">@Model.CityName</li>
        </ol>
    </div>
</nav>

<!-- Hero Section with Gradient -->
<div class="weather-hero" style="background: linear-gradient(135deg, @tempColor 0%, #667eea 50%, #764ba2 100%);">
    <div class="hero-particles" id="particles"></div>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-content fade-in">
                    <h1 class="hero-title">@Model.CityName</h1>
                    <p class="hero-subtitle" data-i18n="RealtimeWeatherConditions">Real-time Weather Conditions</p>
                    <div class="hero-weather">
                        <div class="temperature-hero">
                            @if (Model.WeatherData != null)
                            {
                                <span class="temp-value">@Model.WeatherData.Temperature</span>
                                <span class="temp-unit">°C</span>
                            }
                        </div>
                        @if (Model.WeatherData != null)
                        {
                            @if (!string.IsNullOrEmpty(Model.WeatherData.Icon))
                            {
                                <img src="https://openweathermap.org/img/wn/@(Model.WeatherData.Icon)@@4x.png" 
                                     alt="@Model.WeatherData.Description" 
                                     class="weather-icon-hero"
                                     onerror="this.src='https://openweathermap.org/img/wn/04d@@4x.png'; this.onerror='null';" />
                            }
                            else
                            {
                                <img src="https://openweathermap.org/img/wn/04d@@4x.png" 
                                     alt="Cloudy" 
                                     class="weather-icon-hero" />
                            }
                        }
                    </div>
                    @if (Model.WeatherData != null)
                    {
                        <p class="weather-condition">@Model.WeatherData.Description</p>
                        <p class="feels-like-hero"><span data-i18n="FeelsLike">Feels like</span> @Model.WeatherData.FeelsLike°C</p>
                    }
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-stats slide-in">
                    @if (Model.WeatherData != null)
                    {
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-tint"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value">@Model.WeatherData.Humidity%</div>
                                <div class="stat-label" data-i18n="Humidity">Humidity</div>
                            </div>
                            <div class="stat-progress">
                                <div class="progress-bar" style="width: @Model.WeatherData.Humidity%"></div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-wind"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value">@Model.WeatherData.WindSpeed</div>
                                <div class="stat-label" data-i18n="WindKmh">Wind (km/h)</div>
                            </div>
                            <div class="stat-progress">
                                <div class="progress-bar" style="width: @(Math.Min(Model.WeatherData.WindSpeed * 2, 100))%"></div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-temperature-low"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value">@Model.WeatherData.TempMin°C</div>
                                <div class="stat-label" data-i18n="MinTemp">Min Temp</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-temperature-high"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value">@Model.WeatherData.TempMax°C</div>
                                <div class="stat-label" data-i18n="MaxTemp">Max Temp</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Temperature Range Visualization -->
<div class="container mt-5">
    @if (Model.WeatherData != null)
    {
        <div class="temp-range-card">
            <div class="temp-range-header">
                <h3><i class="fas fa-thermometer-half"></i> <span data-i18n="TemperaturePosition">Temperature Position</span></h3>
            </div>
            <div class="temp-range-body">
                <div class="temp-range-visual">
                    <div class="temp-marker temp-current" style="left: @(((Model.WeatherData.Temperature + 10) / 50) * 100)%">
                        <span class="temp-marker-label" data-i18n="Current">Current</span>
                        <span class="temp-marker-value">@Model.WeatherData.Temperature°C</span>
                    </div>
                </div>
                <div class="temp-range-scale">
                    <span>-10°C</span>
                    <span>0°C</span>
                    <span>10°C</span>
                    <span>20°C</span>
                    <span>30°C</span>
                    <span>40°C</span>
                </div>
            </div>
        </div>
    }
</div>

<!-- 5-Day Forecast Section -->
@if (Model.WeatherData != null)
{
    <div class="forecast-section-details">
        <div class="container">
            <div class="section-header-details">
                <h2><i class="fas fa-calendar-alt"></i> <span data-i18n="FiveDayForecast">5-Day Forecast</span></h2>
                <p data-i18n="WeatherPredictionsNext5Days">Weather predictions for the next 5 days</p>
            </div>
            <div class="forecast-grid-details" data-lat="@Model.WeatherData.Latitude" data-lon="@Model.WeatherData.Longitude">
                <div id="forecast-loading-details" class="forecast-loading-details">
                    <div class="spinner-details"></div>
                    <p data-i18n="LoadingForecast">Loading forecast...</p>
                </div>
                <div id="forecast-error-details" class="forecast-error-details" style="display: none;"></div>
                <div id="forecast-content-details" class="forecast-content-details" style="display: none;"></div>
            </div>
        </div>
    </div>
}

<!-- Detailed Weather Information -->
<div class="container mt-5">
    @if (Model.WeatherData != null)
    {
        <div class="row">
            <!-- Weather Details Card -->
            <div class="col-lg-8">
                <div class="modern-card">
                    <div class="card-header-modern">
                        <h3><i class="fas fa-cloud-sun"></i> <span data-i18n="WeatherDetails">Weather Details</span></h3>
                    </div>
                    <div class="card-body-modern">
                        <div class="weather-grid">
                            <div class="weather-item">
                                <div class="weather-item-icon">
                                    <i class="fas fa-thermometer-half"></i>
                                </div>
                                <div class="weather-item-content">
                                    <span class="weather-item-label" data-i18n="Temperature">Temperature</span>
                                    <span class="weather-item-value">@Model.WeatherData.Temperature°C</span>
                                </div>
                            </div>
                            <div class="weather-item">
                                <div class="weather-item-icon">
                                    <i class="fas fa-tint"></i>
                                </div>
                                <div class="weather-item-content">
                                    <span class="weather-item-label" data-i18n="Humidity">Humidity</span>
                                    <span class="weather-item-value">@Model.WeatherData.Humidity%</span>
                                </div>
                            </div>
                            <div class="weather-item">
                                <div class="weather-item-icon">
                                    <i class="fas fa-wind"></i>
                                </div>
                                <div class="weather-item-content">
                                    <span class="weather-item-label" data-i18n="WindSpeed">Wind Speed</span>
                                    <span class="weather-item-value">@Model.WeatherData.WindSpeed km/h</span>
                                </div>
                            </div>
                            <div class="weather-item">
                                <div class="weather-item-icon">
                                    <i class="fas fa-compress-arrows-alt"></i>
                                </div>
                                <div class="weather-item-content">
                                    <span class="weather-item-label" data-i18n="Pressure">Pressure</span>
                                    <span class="weather-item-value">1013 hPa</span>
                                </div>
                            </div>
                            <div class="weather-item">
                                <div class="weather-item-icon">
                                    <i class="fas fa-eye"></i>
                                </div>
                                <div class="weather-item-content">
                                    <span class="weather-item-label" data-i18n="Visibility">Visibility</span>
                                    <span class="weather-item-value">10 km</span>
                                </div>
                            </div>
                            <div class="weather-item">
                                <div class="weather-item-icon">
                                    <i class="fas fa-map-marker-alt"></i>
                                </div>
                                <div class="weather-item-content">
                                    <span class="weather-item-label" data-i18n="Coordinates">Coordinates</span>
                                    <span class="weather-item-value">@Model.WeatherData.Latitude.ToString("0.0000")°N, @Model.WeatherData.Longitude.ToString("0.0000")°E</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Info Card -->
            <div class="col-lg-4">
                <div class="modern-card info-card">
                    <div class="card-header-modern">
                        <h3><i class="fas fa-info-circle"></i> <span data-i18n="QuickInfo">Quick Info</span></h3>
                    </div>
                    <div class="card-body-modern">
                        <div class="info-item">
                            <span class="info-label" data-i18n="Condition">Condition</span>
                            <span class="info-value">@Model.WeatherData.Description</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label" data-i18n="FeelsLikeShort">Feels Like</span>
                            <span class="info-value">@Model.WeatherData.FeelsLike°C</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label" data-i18n="MinTemperature">Min Temperature</span>
                            <span class="info-value">@Model.WeatherData.TempMin°C</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label" data-i18n="MaxTemperature">Max Temperature</span>
                            <span class="info-value">@Model.WeatherData.TempMax°C</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label" data-i18n="DataUpdated">Data Updated</span>
                            <span class="info-value" data-i18n="JustNow">Just now</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- About Section - Rich Editorial Content -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="modern-card">
                    <div class="card-header-modern">
                        <h3><i class="fas fa-book-open"></i> Understanding Today's Weather in @Model.CityName</h3>
                    </div>
                    <div class="card-body-modern">
                        <div class="about-content">
                            @{
                                var temp = Model.WeatherData.Temperature;
                                var humidity = Model.WeatherData.Humidity;
                                var windSpeed = Model.WeatherData.WindSpeed;
                                var desc = Model.WeatherData.Description;

                                // Interpretation buckets are emitted as translation KEYS so the
                                // client-side translator renders them in the active language.
                                string tempFeelKey, tempAdviceKey;
                                if (temp >= 40) { tempFeelKey = "TempFeel40"; tempAdviceKey = "TempAdvice40"; }
                                else if (temp >= 35) { tempFeelKey = "TempFeel35"; tempAdviceKey = "TempAdvice35"; }
                                else if (temp >= 28) { tempFeelKey = "TempFeel28"; tempAdviceKey = "TempAdvice28"; }
                                else if (temp >= 20) { tempFeelKey = "TempFeel20"; tempAdviceKey = "TempAdvice20"; }
                                else if (temp >= 10) { tempFeelKey = "TempFeel10"; tempAdviceKey = "TempAdvice10"; }
                                else if (temp >= 0) { tempFeelKey = "TempFeel0"; tempAdviceKey = "TempAdvice0"; }
                                else { tempFeelKey = "TempFeelSub0"; tempAdviceKey = "TempAdviceSub0"; }

                                string humidityFeelKey, humidityAdviceKey;
                                if (humidity >= 80) { humidityFeelKey = "HumidityFeel80"; humidityAdviceKey = "HumidityAdvice80"; }
                                else if (humidity >= 60) { humidityFeelKey = "HumidityFeel60"; humidityAdviceKey = "HumidityAdvice60"; }
                                else if (humidity >= 40) { humidityFeelKey = "HumidityFeel40"; humidityAdviceKey = "HumidityAdvice40"; }
                                else if (humidity >= 20) { humidityFeelKey = "HumidityFeel20"; humidityAdviceKey = "HumidityAdvice20"; }
                                else { humidityFeelKey = "HumidityFeel0"; humidityAdviceKey = "HumidityAdvice0"; }

                                string windFeelKey, windAdviceKey;
                                if (windSpeed >= 62) { windFeelKey = "WindFeel62"; windAdviceKey = "WindAdvice62"; }
                                else if (windSpeed >= 39) { windFeelKey = "WindFeel39"; windAdviceKey = "WindAdvice39"; }
                                else if (windSpeed >= 20) { windFeelKey = "WindFeel20"; windAdviceKey = "WindAdvice20"; }
                                else if (windSpeed >= 6) { windFeelKey = "WindFeel6"; windAdviceKey = "WindAdvice6"; }
                                else { windFeelKey = "WindFeel0"; windAdviceKey = "WindAdvice0"; }

                                string planKey = (temp >= 35 || humidity >= 80) ? "hot" : (temp <= 5 ? "cold" : "mild");
                            }

                            <p class="lead">
                                <span data-i18n="CurrentConditionsIn">Current conditions in</span> <strong>@Model.CityName</strong>
                                <span data-i18n="AreConditionWord">are</span> <strong>@desc</strong> <span data-i18n="AtWord">at</span> <strong>@temp°C</strong> —
                                <span data-i18n="ThatsWord">that's</span> <span data-i18n="@tempFeelKey">@tempFeelKey</span> <span data-i18n="ForThisTimeOfDay">for this time of day.</span>
                            </p>

                            <h4>🌡️ <span data-i18n="WhatTemperatureMeans">What This Temperature Means</span></h4>
                            <p data-i18n="@tempAdviceKey">@tempAdviceKey</p>

                            <h4>💧 <span data-i18n="HumidityLabelPlain">Humidity</span>: @humidity% — <span data-i18n="@humidityFeelKey">@humidityFeelKey</span></h4>
                            <p data-i18n="@humidityAdviceKey">@humidityAdviceKey</p>

                            <h4>💨 <span data-i18n="WindLabelPlain">Wind</span>: @windSpeed km/h — <span data-i18n="@windFeelKey">@windFeelKey</span></h4>
                            <p data-i18n="@windAdviceKey">@windAdviceKey</p>

                            <h4>📋 <span data-i18n="PlanningYourDayIn">Planning Your Day in</span> @Model.CityName</h4>
                            @if (planKey == "hot")
                            {
                                <ul>
                                    <li data-i18n="PlanHot1">Schedule outdoor errands before 10 AM or after 5 PM to avoid peak heat.</li>
                                    <li data-i18n="PlanHot2">Carry at least 2 litres of water if spending time outdoors.</li>
                                    <li data-i18n="PlanHot3">Check on elderly neighbours or relatives — heat-related illness can develop rapidly.</li>
                                    <li data-i18n="PlanHot4">Never leave children or pets in parked vehicles, even for a few minutes.</li>
                                    <li data-i18n="PlanHot5">Wear UV-protective clothing or SPF 50+ sunscreen if outdoors for extended periods.</li>
                                </ul>
                            }
                            else if (planKey == "cold")
                            {
                                <ul>
                                    <li data-i18n="PlanCold1">Wear thermal layers and waterproof outer clothing before heading out.</li>
                                    <li data-i18n="PlanCold2">Allow extra time for travel — road conditions may be affected by cold.</li>
                                    <li data-i18n="PlanCold3">Keep a warm drink and emergency blanket in your vehicle.</li>
                                    <li data-i18n="PlanCold4">Check that heating systems at home are working correctly.</li>
                                    <li data-i18n="PlanCold5">Monitor local frost or ice warnings before driving or walking.</li>
                                </ul>
                            }
                            else
                            {
                                <ul>
                                    <li data-i18n="PlanMild1">Conditions are broadly suitable for outdoor plans — check the 5-day forecast above for the week ahead.</li>
                                    <li data-i18n="PlanMild2">If humidity is above 60%, carry water and take shade breaks during physical activity.</li>
                                    <li data-i18n="PlanMild3">Wind may affect cycling routes — factor in headwind on return journeys.</li>
                                    <li data-i18n="PlanMild4">Check the UV index for your area if spending more than 30 minutes outdoors.</li>
                                    <li data-i18n="PlanMild5">Evening temperatures may differ significantly — bring a light layer if going out after dark.</li>
                                </ul>
                            }

                            <h4>📡 <span data-i18n="AboutThisWeatherData">About This Weather Data</span></h4>
                            <p data-i18n="WeatherDataPara1">
                                The weather readings shown are sourced in real time from the OpenWeatherMap API,
                                which aggregates data from thousands of weather stations, satellite observations, and meteorological
                                models worldwide. Temperature values are reported in Celsius at 2 metres above ground level — the
                                standard measurement height used by meteorologists globally. Wind speed is measured at 10 metres
                                above ground and expressed in kilometres per hour. Humidity reflects relative humidity as a percentage
                                of the maximum moisture air can hold at the current temperature.
                            </p>
                            <p data-i18n="WeatherDataPara2">
                                Weather conditions can change rapidly. The 5-day forecast above is updated every 3 hours and uses
                                ensemble modelling to provide the most accurate outlook available. For severe weather events, always
                                follow guidance from your local national meteorological service.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Popular Cities Section -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="modern-card">
                    <div class="card-header-modern">
                        <h3><i class="fas fa-city"></i> <span data-i18n="PopularCities">Popular Cities</span></h3>
                    </div>
                    <div class="card-body-modern">
                        <div class="cities-grid">
                            @if (Model.PopularCities != null && Model.PopularCities.Count > 0)
                            {
                                @foreach (var city in Model.PopularCities)
                                {
                                    var isActive = city.CityName.Equals(Model.CityName, StringComparison.OrdinalIgnoreCase);
                                    <a href="/weather/@city.CityName.ToLower().Replace(" ", "-")" class="city-card @(isActive ? "active" : "")">
                                        <div class="city-card-icon">
                                            <i class="fas fa-cloud-sun"></i>
                                        </div>
                                        <div class="city-card-content">
                                            <span class="city-card-name">@city.CityName</span>
                                            <span class="city-card-label" data-i18n="Weather">Weather</span>
                                        </div>
                                    </a>
                                }
                            }
                            else
                            {
                                <!-- Fallback cities if no search data -->
                                <a href="/weather/kochi" class="city-card">
                                    <div class="city-card-icon">
                                        <i class="fas fa-cloud-sun"></i>
                                    </div>
                                    <div class="city-card-content">
                                        <span class="city-card-name">Kochi</span>
                                        <span class="city-card-label" data-i18n="Weather">Weather</span>
                                    </div>
                                </a>
                                <a href="/weather/mumbai" class="city-card">
                                    <div class="city-card-icon">
                                        <i class="fas fa-cloud-sun"></i>
                                    </div>
                                    <div class="city-card-content">
                                        <span class="city-card-name">Mumbai</span>
                                        <span class="city-card-label" data-i18n="Weather">Weather</span>
                                    </div>
                                </a>
                                <a href="/weather/delhi" class="city-card">
                                    <div class="city-card-icon">
                                        <i class="fas fa-cloud-sun"></i>
                                    </div>
                                    <div class="city-card-content">
                                        <span class="city-card-name">Delhi</span>
                                        <span class="city-card-label" data-i18n="Weather">Weather</span>
                                    </div>
                                </a>
                                <a href="/weather/bangalore" class="city-card">
                                    <div class="city-card-icon">
                                        <i class="fas fa-cloud-sun"></i>
                                    </div>
                                    <div class="city-card-content">
                                        <span class="city-card-name">Bangalore</span>
                                        <span class="city-card-label" data-i18n="Weather">Weather</span>
                                    </div>
                                </a>
                                <a href="/weather/chennai" class="city-card">
                                    <div class="city-card-icon">
                                        <i class="fas fa-cloud-sun"></i>
                                    </div>
                                    <div class="city-card-content">
                                        <span class="city-card-name">Chennai</span>
                                        <span class="city-card-label" data-i18n="Weather">Weather</span>
                                    </div>
                                </a>
                                <a href="/weather/hyderabad" class="city-card">
                                    <div class="city-card-icon">
                                        <i class="fas fa-cloud-sun"></i>
                                    </div>
                                    <div class="city-card-content">
                                        <span class="city-card-name">Hyderabad</span>
                                        <span class="city-card-label" data-i18n="Weather">Weather</span>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert-modern alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <span><span data-i18n="WeatherDataNotAvailable">Weather data not available for</span> @Model.CityName. <span data-i18n="TryAgainLater">Please try again later.</span></span>
        </div>
    }
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    /* Theme Toggle */
    .theme-toggle {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
    }
    
    .theme-btn {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-size: 1.3rem;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        transition: all 0.3s ease;
    }
    
    .theme-btn:hover {
        transform: rotate(180deg) scale(1.1);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
