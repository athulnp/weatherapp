@model WeatherApp.Models.Weather

@{
    // Dynamic meta tags based on weather data
    if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable)
    {
        ViewData["Title"] = $"{Model.CityName} Weather - {Model.Temperature}°C, {Model.Description}";
        ViewData["MetaDescription"] = $"Current weather in {Model.CityName}: {Model.Temperature}°C, {Model.Description}. Humidity: {Model.Humidity}%, Wind: {Model.WindSpeed} km/h. Live weather forecast and conditions.";
        ViewData["MetaKeywords"] = $"{Model.CityName} weather, {Model.CityName} temperature, weather forecast {Model.CityName}, live weather {Model.CityName}, current conditions {Model.CityName}, humidity {Model.CityName}, wind speed {Model.CityName}";
    }
    else
    {
        ViewData["Title"] = "Kairos Weather - Live Weather Updates & Forecast";
        ViewData["MetaDescription"] = "Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide. Real-time weather data with clean, user-friendly interface.";
        ViewData["MetaKeywords"] = "weather, forecast, live weather, temperature, humidity, wind speed, weather app, real-time weather, global weather, weather conditions, climate data";
    }

    // The homepage is served for both "/" and "/?search=...". Point the
    // canonical at the clean homepage (or the dedicated city page when a
    // location is resolved) so search variants don't create duplicate URLs.
    if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable)
    {
        ViewData["Canonical"] = "https://kairosweather.info/weather/" + Model.CityName.ToLower().Replace(" ", "-");
    }
    else
    {
        // Self-canonicalise per language (/, /hi, /ta, /ml) and opt this page in
        // to hreflang alternates so each localized homepage is indexed on its own.
        var homeCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var homePrefix = homeCulture switch { "hi" => "/hi", "ta" => "/ta", "ml" => "/ml", _ => "" };
        ViewData["Canonical"] = "https://kairosweather.info" + (homePrefix == "" ? "/" : homePrefix);
        ViewData["Hreflang"] = "home";
    }
}

@section Head {
    @if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable)
    {
        <!-- Structured Data (Schema.org) JSON-LD for Weather -->
        <script type="application/ld+json">
        {
            "@@context": "https://schema.org",
            "@@type": "WeatherForecast",
            "location": {
                "@@type": "Place",
                "name": "@Model.CityName",
                "geo": {
                    "@@type": "GeoCoordinates",
                    "latitude": @Model?.Latitude ?? 0,
                    "longitude": @Model?.Longitude ?? 0
                }
            },
            "temperature": {
                "@@type": "Temperature",
                "value": @Model?.Temperature ?? 0,
                "unitCode": "CEL"
            },
            "weatherCondition": "@Model?.Description ?? """,
            "humidity": {
                "@@type": "QuantitativeValue",
                "value": @Model?.Humidity ?? 0,
                "unitCode": "PCT"
            },
            "windSpeed": {
                "@@type": "QuantitativeValue",
                "value": @Model?.WindSpeed ?? 0,
                "unitCode": "KMH"
            },
            "feelsLikeTemperature": {
                "@@type": "Temperature",
                "value": @Model?.FeelsLike ?? 0,
                "unitCode": "CEL"
            },
            "tempMax": {
                "@@type": "Temperature",
                "value": @Model?.TempMax ?? 0,
                "unitCode": "CEL"
            },
            "tempMin": {
                "@@type": "Temperature",
                "value": @Model?.TempMin ?? 0,
                "unitCode": "CEL"
            }
        }
        </script>
    }
    else
    {
        <!-- Structured Data (Schema.org) JSON-LD for WebSite -->
        <script type="application/ld+json">
        {
            "@@context": "https://schema.org",
            "@@type": "WebSite",
            "name": "Kairos Weather",
            "url": "https://kairosweather.info/",
            "description": "Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide.",
            "potentialAction": {
                "@@type": "SearchAction",
                "target": "https://kairosweather.info/?search={search_term_string}",
                "query-input": "required name=search_term_string"
            }
        }
        </script>
    }
}

@* Breadcrumb only shown when viewing a specific city — a lone "Home"
   crumb on the landing page is visual clutter. *@
@if (Model != null && !string.IsNullOrEmpty(Model.CityName))
{
    <nav aria-label="Breadcrumb" class="breadcrumb-nav">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="/">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                @Model.CityName Weather
            </li>
        </ol>
    </nav>
}

<!-- Breadcrumb Structured Data -->
@if (Model != null && !string.IsNullOrEmpty(Model.CityName))
{
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://kairosweather.info/"
            },
            {
                "@@type": "ListItem",
                "position": 2,
                "name": "@Model.CityName Weather",
                "item": "https://kairosweather.info/?search=@System.Web.HttpUtility.UrlEncode(Model.CityName)"
            }
        ]
    }
    </script>
}

<!-- FAQ Structured Data for Rich Snippets -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "How do I check the weather for my location?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Simply enter your city name, postal code, or coordinates in the search box on our homepage. You can also use the 'Use My Location' button to automatically detect your current location."
            }
        },
        {
            "@@type": "Question",
            "name": "Is Kairos Weather free to use?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Yes, Kairos Weather is completely free to use. We provide accurate real-time weather data without any subscription fees."
            }
        },
        {
            "@@type": "Question",
            "name": "How accurate is the weather data?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Our weather data is sourced from OpenWeatherMap API, which provides highly accurate and up-to-date weather information from reliable meteorological sources worldwide."
            }
        },
        {
            "@@type": "Question",
            "name": "Can I check weather for any location worldwide?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Yes, Kairos Weather supports weather data for locations worldwide. You can search for cities, postal codes, or coordinates from any country."
            }
        },
        {
            "@@type": "Question",
            "name": "What weather information is provided?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "We provide current temperature, feels-like temperature, humidity, wind speed, weather conditions, and other meteorological data for your selected location."
            }
        }
    ]
}
</script>

<!-- HowTo Structured Data for Weather Guides -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "HowTo",
    "name": "How to Check Weather for Any Location",
