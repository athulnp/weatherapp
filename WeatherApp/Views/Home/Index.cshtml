<!-- Weather Safety Section -->
<section class="weather-safety-section">
    <div class="weather-safety-container">
        <h2 class="section-title" data-i18n="WeatherSafety">🛡️ Weather Safety</h2>
        <div class="safety-content">
            <div class="safety-item">
                <h3 data-i18n="HeatWaveSafety">Heat Wave Safety</h3>
                <p data-i18n="HeatWaveSafetyDesc">During extreme heat, stay in air-conditioned buildings, limit outdoor activities, and recognize signs of heat exhaustion like heavy sweating, weakness, and dizziness.</p>
            </div>
            <div class="safety-item">
                <h3 data-i18n="FloodSafety">Flood Safety</h3>
                <p data-i18n="FloodSafetyDesc">Never walk or drive through floodwaters. Just 6 inches of moving water can knock you down, and 1 foot of water can sweep your vehicle away. Move to higher ground immediately.</p>
            </div>
            <div class="safety-item">
                <h3 data-i18n="ThunderstormSafety">Thunderstorm Safety</h3>
                <p data-i18n="ThunderstormSafetyDesc">When thunder roars, go indoors! Avoid using electrical appliances and plumbing during storms. If you're outside, avoid open fields, tall trees, and water bodies.</p>
            </div>
            <div class="safety-item">
                <h3 data-i18n="ColdWaveSafety">Cold Wave Safety</h3>
                <p data-i18n="ColdWaveSafetyDesc">Stay indoors during extreme cold. If you must go outside, dress in layers and cover exposed skin. Watch for signs of frostbite and hypothermia.</p>
            </div>
        </div>
    </div>
</section>

