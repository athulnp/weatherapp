<script>
    function loadForecast() {
        var forecastSection = document.querySelector('.forecast-section');
        var lat = parseFloat(forecastSection ? forecastSection.dataset.lat : 0);
        var lon = parseFloat(forecastSection ? forecastSection.dataset.lon : 0);

        if (lat === 0 || lon === 0) {
            alert('Location coordinates not available');
            return;
        }
        
        const btn = document.getElementById('load-forecast-btn');
        const loading = document.getElementById('forecast-loading');
        const error = document.getElementById('forecast-error');
        const content = document.getElementById('forecast-content');
        
        btn.disabled = true;
        loading.style.display = 'block';
        error.style.display = 'none';
        content.style.display = 'none';
        
        fetch('/Home/GetForecast?lat=' + lat + '&lon=' + lon)
            .then(response => response.json())
            .then(data => {
                loading.style.display = 'none';
                btn.disabled = false;
                
                if (data.success && data.data && data.data.length > 0) {
                    content.innerHTML = data.data.map(day => {
                        const date = new Date(day.dt * 1000);
                        const dayName = date.toLocaleDateString('en-US', { weekday: 'long' });
                        const formattedDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                        const icon = day.weather && day.weather[0] ? day.weather[0].icon : '01d';
                        const iconUrl = 'https://openweathermap.org/img/wn/' + icon + '@@2x.png';
                        const description = day.weather && day.weather[0] ? day.weather[0].description : '';
                        
                        return `
                            <div class="forecast-card">
                                <div class="forecast-date">
                                    <span class="day-name">${dayName}</span>
                                    <span class="date-text">${formattedDate}</span>
                                </div>
                                <div class="forecast-icon">
                                    <img src="${iconUrl}" alt="${description}" loading="lazy" width="64" height="64" />
                                </div>
                                <div class="forecast-temp">
                                    <span class="temp-max">${Math.round(day.temp.max)}°</span>
                                    <span class="temp-min">${Math.round(day.temp.min)}°</span>
                                </div>
                                <div class="forecast-desc">${description}</div>
                                <div class="forecast-details">
                                    <span class="forecast-detail">💧 ${day.humidity}%</span>
                                    <span class="forecast-detail">💨 ${Math.round(day.windSpeed)} km/h</span>
                                </div>
                            </div>
                        `;
                    }).join('');
                    content.style.display = 'grid';
                } else {
                    error.textContent = data.error || 'Failed to load forecast data';
                    error.style.display = 'block';
                }
            })
            .catch(err => {
                loading.style.display = 'none';
                btn.disabled = false;
                error.textContent = 'Error loading forecast. Please try again.';
                error.style.display = 'block';
                console.error('Error:', err);
            });
    }
</script>

<script>
// AJAX Search Functionality
document.addEventListener("DOMContentLoaded", function() {
    const searchForm = document.querySelector(".hero-search-form");
    const searchResultsSection = document.getElementById("search-results-section");
    const closeResultsBtn = document.getElementById("close-search-results");
    const searchInput = document.querySelector(".search-input");
    
    if (searchForm) {
        searchForm.addEventListener("submit", function(e) {
            e.preventDefault();
            
            const cityName = searchInput.value.trim();
            if (!cityName) return;
            
            performSearch(cityName);
        });
    }
    
    if (closeResultsBtn) {
        closeResultsBtn.addEventListener("click", function() {
            searchResultsSection.style.display = "none";
        });
    }
});

function performSearch(cityName) {
    const searchResultsSection = document.getElementById("search-results-section");
    const loadingDiv = document.getElementById("search-result-loading");
    const errorDiv = document.getElementById("search-result-error");
    const contentDiv = document.getElementById("search-result-content");
    const titleDiv = document.getElementById("search-result-title");
    
    // Show section and loading state
    searchResultsSection.style.display = "block";
    loadingDiv.style.display = "flex";
    errorDiv.style.display = "none";
    contentDiv.innerHTML = "";

    // Scroll to the search results section
    searchResultsSection.scrollIntoView({ behavior: "smooth", block: "start" });

    // Fetch search results
    fetch(`/Home/SearchWeather?cityName=${encodeURIComponent(cityName)}`)
        .then(response => response.json())
        .then(data => {
            loadingDiv.style.display = "none";
            
            if (data.success && data.data) {
                const weather = data.data;
                titleDiv.textContent = weather.cityName + " Weather";
                
                contentDiv.innerHTML = `
                    <div class="search-result-card">
                        <div class="search-result-main">
                            <div class="search-result-weather-info">
                                <div class="search-result-temp-wrapper">
                                    <span class="temp-value">${Math.round(weather.temperature)}</span>
                                    <span class="temp-unit">°C</span>
                                </div>
                                <div class="search-result-meta">
                                    <p class="weather-description">${weather.description}</p>
                                    <span class="weather-location">${weather.cityName}</span>
                                </div>
                            </div>
                            <div class="search-result-icon">
                                <img src="${weather.icon}" alt="${weather.description}" loading="lazy" width="100" height="100" />
                            </div>
                        </div>
                        <div class="search-result-details">
                            <div class="detail-card">
                                <div class="detail-icon">🌡️</div>
                                <div class="detail-info">
                                    <span class="detail-label">Feels Like</span>
                                    <span class="detail-value">${Math.round(weather.feelsLike)}°C</span>
                                </div>
                            </div>
                            <div class="detail-card">
                                <div class="detail-icon">💧</div>
                                <div class="detail-info">
                                    <span class="detail-label">Humidity</span>
                                    <span class="detail-value">${weather.humidity}%</span>
                                </div>
                            </div>
                            <div class="detail-card">
                                <div class="detail-icon">💨</div>
                                <div class="detail-info">
                                    <span class="detail-label">Wind Speed</span>
                                    <span class="detail-value">${weather.windSpeed} km/h</span>
                                </div>
                            </div>
                        </div>
                        <a href="/weather/${weather.cityName.toLowerCase().replace(/\\s+/g, '-')}" class="search-result-link">
                            <span>View Full Report</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14"></path>
                                <path d="M12 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    </div>
                `;
                errorDiv.style.display = "none";
            } else {
                errorDiv.textContent = data.error || "Failed to load weather data";
                errorDiv.style.display = "block";
            }
        })
        .catch(error => {
            loadingDiv.style.display = "none";
            errorDiv.textContent = "Error loading weather data. Please try again.";
            errorDiv.style.display = "block";
            console.error("Search error:", error);
        });
}
</script>

