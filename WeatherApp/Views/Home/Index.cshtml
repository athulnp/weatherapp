<!-- Weather Tips Section -->
<section class="weather-tips-section">
    <div class="weather-tips-container">
        <h2 class="section-title">💡 Weather Tips</h2>
        <div class="tips-grid">
            <div class="tip-card">
                <h3>☀️ Hot Weather</h3>
                <ul>
                    <li>Stay hydrated - drink plenty of water</li>
                    <li>Wear light-colored, loose-fitting clothing</li>
                    <li>Avoid direct sunlight during peak hours (10 AM - 4 PM)</li>
                    <li>Use sunscreen with SPF 30 or higher</li>
                    <li>Check on elderly neighbors and pets</li>
                </ul>
            </div>
            <div class="tip-card">
                <h3>🌧️ Rainy Weather</h3>
                <ul>
                    <li>Carry an umbrella or raincoat</li>
                    <li>Wear waterproof footwear</li>
                    <li>Drive slowly and maintain safe distance</li>
                    <li>Avoid walking through flooded areas</li>
                    <li>Keep emergency numbers handy</li>
                </ul>
            </div>
            <div class="tip-card">
                <h3>❄️ Cold Weather</h3>
                <ul>
                    <li>Layer your clothing for warmth</li>
                    <li>Wear a hat, gloves, and scarf</li>
                    <li>Stay dry to prevent hypothermia</li>
                    <li>Keep your home heated safely</li>
                    <li>Check weather forecasts before traveling</li>
                </ul>
            </div>
            <div class="tip-card">
                <h3>🌪️ Stormy Weather</h3>
                <ul>
                    <li>Stay indoors during storms</li>
                    <li>Avoid windows and doors</li>
                    <li>Unplug electronic devices</li>
                    <li>Have an emergency kit ready</li>
                    <li>Follow local weather alerts</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Weather Safety Section -->
<section class="weather-safety-section">
    <div class="weather-safety-container">
        <h2 class="section-title">🛡️ Weather Safety</h2>
        <div class="safety-content">
            <div class="safety-item">
                <h3>Heat Wave Safety</h3>
                <p>During extreme heat, stay in air-conditioned buildings, limit outdoor activities, and recognize signs of heat exhaustion like heavy sweating, weakness, and dizziness.</p>
            </div>
            <div class="safety-item">
                <h3>Flood Safety</h3>
                <p>Never walk or drive through floodwaters. Just 6 inches of moving water can knock you down, and 1 foot of water can sweep your vehicle away. Move to higher ground immediately.</p>
            </div>
            <div class="safety-item">
                <h3>Thunderstorm Safety</h3>
                <p>When thunder roars, go indoors! Avoid using electrical appliances and plumbing during storms. If you're outside, avoid open fields, tall trees, and water bodies.</p>
            </div>
            <div class="safety-item">
                <h3>Cold Wave Safety</h3>
                <p>Stay indoors during extreme cold. If you must go outside, dress in layers and cover exposed skin. Watch for signs of frostbite and hypothermia.</p>
            </div>
        </div>
    </div>
</section>

<!-- Seasonal Weather Information -->
<section class="seasonal-weather-section">
    <div class="seasonal-weather-container">
        <h2 class="section-title">📅 Seasonal Weather Guide</h2>
        <div class="seasonal-grid">
            <div class="season-card">
                <h3>🌸 Spring (March-May)</h3>
                <p>Mild temperatures with occasional rain. Perfect for outdoor activities. Carry a light jacket for cool evenings.</p>
            </div>
            <div class="season-card">
                <h3>☀️ Summer (June-August)</h3>
                <p>Hot and humid with temperatures reaching 35°C+. Stay hydrated, use sunscreen, and avoid peak sun hours.</p>
            </div>
            <div class="season-card">
                <h3>🍂 Autumn (September-November)</h3>
                <p>Pleasant weather with cooler temperatures. Ideal for travel and outdoor events. Light layers work best.</p>
            </div>
            <div class="season-card">
                <h3>❄️ Winter (December-February)</h3>
                <p>Cold temperatures with possible frost. Wear warm clothing, use heating, and protect exposed skin from cold winds.</p>
            </div>
        </div>
    </div>
</section>

<style>
