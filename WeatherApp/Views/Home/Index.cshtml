}
</script>

<!-- Speakable Schema for Voice Search -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "SpeakableSpecification",
    "@@id": "#speakable",
    "cssSelector": [
        ".hero-title",
        ".hero-subtitle",
        ".weather-location"
    ],
    "xpath": [
        "/html/body/section/div/h1",
        "/html/body/section/div/p",
        "/html/body/div/div/h2"
    ]
}
</script>

<!-- Hero Section with Search -->
<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title" data-i18n="HeroTitle">
            <span class="hero-icon">🌤️</span>
            Kairos Weather - Live Weather Updates & Forecast
        </h1>
        <p class="hero-subtitle" data-i18n="HeroSubtitle">Real-time weather updates for any location worldwide. Check current temperature, humidity, wind speed, and weather conditions.</p>

        <!-- Search Form -->
        <form id="hero-search-form" method="post" asp-controller="Home" asp-action="Index" class="hero-search-form" role="search" aria-label="Weather search">
            <div class="search-input-wrapper">
                <input type="text" name="CityName" placeholder="Enter city name, postal code, or coordinates..." required aria-required="true" autocomplete="off" class="search-input" />
                <button type="submit" class="search-button" aria-label="Search weather" data-i18n="SearchButton">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.3-4.3"></path>
                    </svg>
                </button>
            </div>
            <p class="search-hint" data-i18n="SearchHint">Try: "Kochi", "682001", or "9.9312,76.2673"</p>
        </form>
    </div>
</section>

<!-- Search Results Section (Inline - Right below search) -->
<section id="search-results-section" class="search-results-section" style="display: none;">
    <div class="search-results-container">
        <button class="search-results-close" id="close-search-results" aria-label="Close search results">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        <div class="search-results-header">
            <h2 id="search-result-title" class="search-results-title">Search Results</h2>
        </div>
        <div id="search-result-content" class="search-results-body">
            <!-- Results will be loaded here -->
        </div>
        <div id="search-result-error" class="search-results-error" style="display: none;"></div>
        <div id="search-result-loading" class="search-results-loading" style="display: none;">
            <div class="loading-spinner"></div>
            <p>Loading weather data...</p>
        </div>
    </div>
</section>

<!-- Search Results Section (Priority - Just below search bar) -->
@if (Model != null && !string.IsNullOrEmpty(Model.CityName)) {
    <section id="search-results-display" class="weather-display-section search-results-section">
        <div class="weather-display-container">
            <div class="section-header">
                <h2 class="section-title">@Model.CityName</h2>
                <span class="section-subtitle" data-i18n="WeatherReport">Weather Report</span>
            </div>

            @if (Model.IsLocationAvailable) {
                <div class="weather-card search-result-card simplified">
                    <a href="/weather/@Model.CityName.ToLower().Replace(" ", "-")" class="weather-card-link">
                        <div class="weather-card-content">
                            <div class="weather-card-left">
                                <div class="weather-temperature">
                                    <span class="temperature-value">@Math.Round(Model.Temperature)</span>
                                    <span class="temperature-unit">°C</span>
                                </div>
                                <p class="weather-description">@Model.Description</p>
                            </div>

                            <div class="weather-card-right">
                                <img src="@Model.Icon" alt="@Model.Description weather icon" class="weather-icon" loading="lazy" width="100" height="100" />
                            </div>
                        </div>
                        <div class="view-details-link">
                            <span>View Full Report</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14"></path>
                                <path d="M12 5l7 7-7 7"></path>
                            </svg>
                        </div>
                    </a>
                </div>
            } else {
                <div class="weather-error-card">
                    <div class="error-icon">❌</div>
                    <h3>Location Not Found</h3>
                    <p>@Model.Description</p>
                    <button onclick="window.location.reload()" class="retry-button">Try Again</button>
                </div>
            }
        </div>
    </section>
}

<!-- 5-Day Forecast Section -->
@if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable) {
    <section class="forecast-section" data-lat="@Model?.Latitude" data-lon="@Model?.Longitude">
        <div class="forecast-container">
            <div class="section-header">
                <h2 class="section-title">@Model.CityName</h2>
                <span class="section-subtitle" data-i18n="FiveDayForecast">5-Day Forecast</span>
                <button id="load-forecast-btn" class="load-forecast-button" onclick="loadForecast()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                        <path d="M3 3v5h5"></path>
                        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path>
                        <path d="M16 21h5v-5"></path>
                    </svg>
                    <span data-i18n="LoadForecast">Load Forecast</span>
                </button>
            </div>
            
            <div id="forecast-loading" class="forecast-loading" style="display: none;">
                <div class="spinner"></div>
                <p>Loading forecast...</p>
            </div>
            
            <div id="forecast-error" class="forecast-error" style="display: none;"></div>
            
            <div id="forecast-content" class="forecast-grid" style="display: none;">
            </div>
        </div>
    </section>
}

