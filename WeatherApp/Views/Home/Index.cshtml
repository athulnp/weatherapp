                    <li data-i18n="ColdWeatherTip2">Wear a hat, gloves, and scarf</li>
                    <li data-i18n="ColdWeatherTip3">Stay dry to prevent hypothermia</li>
                    <li data-i18n="ColdWeatherTip4">Keep your home heated safely</li>
                    <li data-i18n="ColdWeatherTip5">Check weather forecasts before traveling</li>
                </ul>
