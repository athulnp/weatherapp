            <div class="tip-card">
                <h3 data-i18n="RainyWeather">🌧️ Rainy Weather</h3>
                <ul>
                    <li data-i18n="RainyWeatherTip1">Carry an umbrella or raincoat</li>
                    <li data-i18n="RainyWeatherTip2">Wear waterproof footwear</li>
                    <li data-i18n="RainyWeatherTip3">Drive slowly and maintain safe distance</li>
                    <li data-i18n="RainyWeatherTip4">Avoid walking through flooded areas</li>
                    <li data-i18n="RainyWeatherTip5">Keep emergency numbers handy</li>
