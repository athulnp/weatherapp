<!-- Speakable Schema for Voice Search -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "SpeakableSpecification",
    "@@id": "#speakable",
    "cssSelector": [
        ".hero-title",
        ".hero-subtitle",
        ".weather-location"
    ],
    "xpath": [
        "/html/body/section/div/h1",
        "/html/body/section/div/p",
        "/html/body/div/div/h2"
    ]
}
</script>

<!-- Hero Section with Search -->
<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">
            <span class="hero-icon">🌤️</span>
            Kairos Weather - Live Weather Updates & Forecast
        </h1>
        <p class="hero-subtitle">Real-time weather updates for any location worldwide. Check current temperature, humidity, wind speed, and weather conditions.</p>
        
        <!-- Search Form -->
        <form method="post" asp-controller="Home" asp-action="Index" class="hero-search-form" role="search" aria-label="Weather search">
            <div class="search-input-wrapper">
                <input type="text" name="CityName" placeholder="Search city, postal code, or coordinates..." required aria-required="true" autocomplete="off" class="search-input" />
                <button type="submit" class="search-button" aria-label="Search weather">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.3-4.3"></path>
                    </svg>
                </button>
            </div>
            <p class="search-hint">Try: "Kochi", "682001", or "9.9312,76.2673"</p>
        </form>
    </div>
</section>

<!-- Search Results Section (Priority - Just below search bar) -->
@if (Model != null && !string.IsNullOrEmpty(Model.CityName)) {
    <section class="weather-display-section search-results-section">
        <div class="weather-display-container">
            <div class="section-header">
                <h2 class="section-title">@Model.CityName</h2>
                <span class="section-subtitle">Weather Report</span>
            </div>

            @if (Model.IsLocationAvailable) {
                <div class="weather-card search-result-card">
                    <div class="weather-card-content">
                        <div class="weather-card-left">
                            <div class="weather-temperature">
                                <span class="temperature-value">@Math.Round(Model.Temperature)</span>
                                <span class="temperature-unit">°C</span>
                            </div>
                            <p class="weather-description">@Model.Description</p>
                        </div>

                        <div class="weather-card-right">
                            <img src="@Model.Icon" alt="@Model.Description weather icon" class="weather-icon" loading="lazy" width="100" height="100" />
                        </div>
                    </div>

                    <div class="weather-details-grid">
                        <div class="weather-detail-item">
                            <span class="detail-icon">🌡️</span>
                            <div class="detail-info">
                                <span class="detail-label">Feels Like</span>
                                <span class="detail-value">@Math.Round(Model.FeelsLike)°C</span>
                            </div>
                        </div>
                        <div class="weather-detail-item">
                            <span class="detail-icon">⬆️</span>
                            <div class="detail-info">
                                <span class="detail-label">High</span>
                                <span class="detail-value">@Math.Round(Model.TempMax)°C</span>
                            </div>
                        </div>
                        <div class="weather-detail-item">
                            <span class="detail-icon">⬇️</span>
                            <div class="detail-info">
                                <span class="detail-label">Low</span>
                                <span class="detail-value">@Math.Round(Model.TempMin)°C</span>
                            </div>
                        </div>
                        <div class="weather-detail-item">
                            <span class="detail-icon">💧</span>
                            <div class="detail-info">
                                <span class="detail-label">Humidity</span>
                                <span class="detail-value">@Model.Humidity%</span>
                            </div>
                        </div>
                        <div class="weather-detail-item">
                            <span class="detail-icon">💨</span>
                            <div class="detail-info">
                                <span class="detail-label">Wind</span>
                                <span class="detail-value">@Model.WindSpeed km/h</span>
                            </div>
                        </div>
                    </div>
                </div>
            } else {
                <div class="weather-error-card">
                    <div class="error-icon">❌</div>
                    <h3>Location Not Found</h3>
                    <p>@Model.Description</p>
                    <button onclick="window.location.reload()" class="retry-button">Try Again</button>
                </div>
            }
        </div>
    </section>
}

<!-- 5-Day Forecast Section -->
@if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable) {
    <section class="forecast-section" data-lat="@Model?.Latitude" data-lon="@Model?.Longitude">
        <div class="forecast-container">
            <div class="section-header">
                <h2 class="section-title">@Model.CityName</h2>
                <span class="section-subtitle">5-Day Forecast</span>
                <button id="load-forecast-btn" class="load-forecast-button" onclick="loadForecast()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                        <path d="M3 3v5h5"></path>
                        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path>
                        <path d="M16 21h5v-5"></path>
                    </svg>
                    Load Forecast
                </button>
            </div>
            
            <div id="forecast-loading" class="forecast-loading" style="display: none;">
                <div class="spinner"></div>
                <p>Loading forecast...</p>
            </div>
            
            <div id="forecast-error" class="forecast-error" style="display: none;"></div>
            
            <div id="forecast-content" class="forecast-grid" style="display: none;">
            </div>
        </div>
    </section>
}

<!-- Current Location Weather Section (Secondary - Below search results) -->
<section class="weather-display-section current-location-section">
    <div class="weather-display-container">
        <div class="section-header">
            <h2 class="section-title">📍 Your Location</h2>
        </div>
        
        <!-- Location Loading -->
        <div id="location-loading" class="weather-loading-card" style="display: none;">
            <div class="spinner"></div>
            <p>Getting your location...</p>
        </div>
        
        <!-- Location Error -->
        <div id="location-error" class="weather-error-card" style="display: none;"></div>
        
        <!-- Current Location Weather -->
        <div id="current-location-weather" class="weather-card" style="display: none;"></div>
        
        <!-- Empty State -->
        <div id="current-location-empty" class="weather-empty-card">
            <div class="empty-icon">📍</div>
            <p>Get weather for your current location</p>
            <button id="get-current-location" class="location-button">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
                Use My Location
            </button>
        </div>
    </div>
</section>

