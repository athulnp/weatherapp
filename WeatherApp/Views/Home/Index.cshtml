@{
    // Dynamic meta tags based on weather data
    if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable)
    {
        ViewData["Title"] = $"{Model.CityName} Weather - {Model.Temperature}°C, {Model.Description}";
        ViewData["MetaDescription"] = $"Current weather in {Model.CityName}: {Model.Temperature}°C, {Model.Description}. Humidity: {Model.Humidity}%, Wind: {Model.WindSpeed} km/h. Live weather forecast and conditions.";
        ViewData["MetaKeywords"] = $"{Model.CityName} weather, {Model.CityName} temperature, weather forecast {Model.CityName}, live weather {Model.CityName}, current conditions {Model.CityName}, humidity {Model.CityName}, wind speed {Model.CityName}";
    }
    else
    {
        ViewData["Title"] = "Kairos Weather - Live Weather Updates & Forecast";
        ViewData["MetaDescription"] = "Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide. Real-time weather data with clean, user-friendly interface.";
        ViewData["MetaKeywords"] = "weather, forecast, live weather, temperature, humidity, wind speed, weather app, real-time weather, global weather, weather conditions, climate data";
    }
}

@section Head {
    @if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
        <meta name="keywords" content="@ViewData["MetaKeywords"]" />
        
        <!-- Dynamic Open Graph tags -->
        <meta property="og:title" content="@ViewData["Title"]" />
        <meta property="og:description" content="@ViewData["MetaDescription"]" />
        <meta property="og:url" content="@("https://kairosweather.info/?search=" + System.Web.HttpUtility.UrlEncode(Model.CityName))" />
        
        <!-- Dynamic Twitter tags -->
        <meta property="twitter:title" content="@ViewData["Title"]" />
        <meta property="twitter:description" content="@ViewData["MetaDescription"]" />
    }
}

<!-- WeatherForecast Structured Data -->
@if (Model != null && !string.IsNullOrEmpty(Model.CityName) && Model.IsLocationAvailable)
{
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WeatherForecast",
        "name": "@Model.CityName",
        "description": "@Model.Description",
        "temperature": {
            "@@type": "QuantitativeValue",
            "value": "@Model.Temperature",
            "unitCode": "CEL"
        },
        "feelsLike": {
            "@@type": "QuantitativeValue",
            "value": "@Model.FeelsLike",
            "unitCode": "CEL"
        },
        "tempMax": {
            "@@type": "QuantitativeValue",
            "value": "@Model.TempMax",
            "unitCode": "CEL"
        },
        "tempMin": {
            "@@type": "QuantitativeValue",
            "value": "@Model.TempMin",
            "unitCode": "CEL"
        },
        "humidity": {
            "@@type": "QuantitativeValue",
            "value": "@Model.Humidity",
            "unitCode": "PCT"
        },
        "windSpeed": {
            "@@type": "QuantitativeValue",
            "value": "@Model.WindSpeed",
            "unitCode": "KMH"
        },
        "weatherCondition": "@Model.Description",
        "dateIssued": "@DateTime.UtcNow.ToString("o")",
        "location": {
            "@@type": "Place",
            "name": "@Model.CityName"
        }
    }
    </script>
}

<!-- 7-Day Forecast Structured Data -->
@if (Model != null && Model.Forecast != null && Model.Forecast.Count > 0)
{
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WeatherForecast",
        "name": "@Model.CityName 7-Day Forecast",
        "description": "7-day weather forecast for @Model.CityName",
        "location": {
            "@@type": "Place",
            "name": "@Model.CityName"
        },
        "forecast": [
            @for (int i = 0; i < Model.Forecast.Count; i++)
            {
                var day = Model.Forecast[i];
                var date = DateTimeOffset.FromUnixTimeSeconds(day.Dt).DateTime.ToString("o");
                if (i > 0) { <text>,</text> }
                <text>
                {
                    "@@type": "WeatherForecast",
                    "name": "@date",
                    "temperature": {
                        "@@type": "QuantitativeValue",
                        "value": "@day.Temp.Day",
                        "unitCode": "CEL"
                    },
                    "tempMax": {
                        "@@type": "QuantitativeValue",
                        "value": "@day.Temp.Max",
                        "unitCode": "CEL"
                    },
                    "tempMin": {
                        "@@type": "QuantitativeValue",
                        "value": "@day.Temp.Min",
                        "unitCode": "CEL"
                    },
                    "humidity": {
                        "@@type": "QuantitativeValue",
                        "value": "@day.Humidity",
                        "unitCode": "PCT"
                    },
                    "windSpeed": {
                        "@@type": "QuantitativeValue",
                        "value": "@day.WindSpeed",
                        "unitCode": "KMH"
                    },
                    "weatherCondition": "@(day.Weather?.FirstOrDefault()?.Description ?? "")",
                    "dateIssued": "@date"
                }
                </text>
            }
        ]
    }
    </script>
}

