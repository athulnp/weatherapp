            // Map full locale keys to the URL prefix (English has none).
            const langPrefixMap = { 'hi-IN': '/hi', 'ta-IN': '/ta', 'ml-IN': '/ml', 'en-US': '' };

            function setLanguage(lang) {
                localStorage.setItem('selectedLanguage', lang);

                // Navigate to the language-prefixed URL so the choice is reflected
                // in a crawlable URL (and the server renders in that language).
                const targetPrefix = langPrefixMap[lang] || '';
                let path = window.location.pathname;
                // Strip any existing language prefix first.
                path = path.replace(/^\/(hi|ta|ml)(?=\/|$)/, '');
                if (path === '') { path = '/'; }
                const newPath = (targetPrefix + (path === '/' ? '' : path)) || '/';
                const dest = newPath + window.location.search + window.location.hash;

                if (dest !== (window.location.pathname + window.location.search + window.location.hash)) {
                    window.location.href = dest;
                } else {
                    applyTranslations(lang);
                }
            }

            function applyTranslations(lang) {
                const langTranslations = translations[lang] || translations['en-US'];
                
                const searchInput = document.querySelector('input[name="CityName"]');
                if (searchInput) {
                    searchInput.placeholder = langTranslations['SearchPlaceholder'];
                }

                document.querySelectorAll('[data-i18n]').forEach(element => {
                    const key = element.getAttribute('data-i18n');
                    if (langTranslations[key]) {
                        element.textContent = langTranslations[key];
                    }
                });

                // Translate placeholder attributes (search boxes, email inputs, etc.).
                document.querySelectorAll('[data-i18n-placeholder]').forEach(element => {
                    const key = element.getAttribute('data-i18n-placeholder');
                    if (langTranslations[key]) {
                        element.setAttribute('placeholder', langTranslations[key]);
                    }
                });
            }

            // The server sets the language from the URL prefix (/hi, /ta, /ml) so
            // crawlers see translated content per URL. Map the two-letter culture
            // to the full locale key used by the translations dictionary.
            const serverLangMap = { 'hi': 'hi-IN', 'ta': 'ta-IN', 'ml': 'ml-IN', 'en': 'en-US' };
            const serverLang = serverLangMap['@htmlLang'] || 'en-US';

            document.addEventListener('DOMContentLoaded', function() {
                // URL-derived culture wins; fall back to a previously saved choice.
                const savedLang = serverLang || localStorage.getItem('selectedLanguage') || 'en-US';
                applyTranslations(savedLang);

                document.querySelectorAll('.language-switcher').forEach(link => {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        const lang = this.getAttribute('data-lang');
                        setLanguage(lang);
                    });
                });

                // Keep the active language prefix across navigation. Internal links
                // are generated without a prefix, so when the current URL is
                // language-prefixed we rewrite same-site links to preserve it.
                const activePrefix = (window.location.pathname.match(/^\/(hi|ta|ml)(?=\/|$)/) || [])[0];
                if (activePrefix) {
                    document.querySelectorAll('a[href]').forEach(a => {
                        const raw = a.getAttribute('href');
                        if (!raw || raw.startsWith('#')) return;
                        // Only same-origin, root-relative internal links.
                        if (!raw.startsWith('/') || raw.startsWith('//')) return;
                        // Skip already-prefixed links, admin, and the language switcher.
                        if (/^\/(hi|ta|ml)(\/|$)/.test(raw)) return;
                        if (raw.startsWith('/admin')) return;
                        if (a.classList.contains('language-switcher')) return;
                        a.setAttribute('href', activePrefix + (raw === '/' ? '' : raw));
                    });
                }
            });
        </script>
