<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-WCBGDMDM96"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-WCBGDMDM96');
    </script>

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3262579139378205" crossorigin="anonymous"></script>
    <script>
        (adsbygoogle = window.adsbygoogle || []).push({
            google_ad_client: "ca-pub-3262579139378205",
            enable_page_level_ads: true
        });
    </script>
    
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Primary Meta Tags -->
    <title>@ViewData["Title"]</title>
    <meta name="title" content="@ViewData["Title"]" />
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide. Real-time weather data with clean, user-friendly interface.")" />
    <meta name="keywords" content="@(ViewData["MetaKeywords"] ?? "weather, forecast, live weather, temperature, humidity, wind speed, weather app, real-time weather, global weather, weather conditions, climate data")" />
    <meta name="author" content="Kairos Weather" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="language" content="English" />
    <meta name="theme-color" content="#667eea" />
    
    <!-- Dynamic meta tags from views -->
    @await RenderSectionAsync("Head", required: false)
    
    <!-- Performance Optimization -->
    <link rel="dns-prefetch" href="https://api.openweathermap.org" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    
    <!-- Preconnect for critical resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.openweathermap.org" />
    
    <!-- Preload critical CSS -->
    <link rel="preload" href="~/css/site.css" as="style" />
    <link rel="preload" href="~/css/weather.css" as="style" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    
    <!-- Alternate Language Links -->
    <link rel="alternate" hreflang="en" href="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    <link rel="alternate" hreflang="hi" href="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    <link rel="alternate" hreflang="ta" href="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    <link rel="alternate" hreflang="ml" href="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    <link rel="alternate" hreflang="x-default" href="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    
    <!-- Language meta tags -->
    <meta name="content-language" content="en" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    <meta property="og:title" content="@ViewData["Title"] - Kairos Weather | Live Weather Updates" />
    <meta property="og:description" content="Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide." />
    <meta property="og:image" content="https://kairosweather.info/assets/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Kairos Weather App - Live Weather Updates" />
    <meta property="og:site_name" content="Kairos Weather" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="@("https://kairosweather.info" + Context.Request.Path.Value)" />
    <meta property="twitter:title" content="@ViewData["Title"] - Kairos Weather | Live Weather Updates" />
    <meta property="twitter:description" content="Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide." />
    <meta property="twitter:image" content="https://kairosweather.info/assets/twitter-image.png" />
    <meta property="twitter:site" content="@@KairosWeather" />
    <meta property="twitter:creator" content="@@KairosWeather" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/weather.css" asp-append-version="true" />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebSite",
        "name": "Kairos Weather",
        "url": "https://kairosweather.info",
        "description": "Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide.",
        "potentialAction": {
            "@@type": "SearchAction",
            "target": "https://kairosweather.info/?search={search_term_string}",
            "query-input": "required name=search_term_string"
        },
        "publisher": {
            "@@type": "Organization",
            "name": "Kairos Weather",
            "url": "https://kairosweather.info",
            "logo": {
                "@@type": "ImageObject",
                "url": "https://kairosweather.info/assets/logo.png",
                "width": 512,
                "height": 512
            }
        }
    }
    </script>
    
    <!-- Navigation Structured Data -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://kairosweather.info"
            },
            {
                "@@type": "ListItem",
                "position": 2,
                "name": "About",
                "item": "https://kairosweather.info/Static/About"
            },
            {
                "@@type": "ListItem",
                "position": 3,
                "name": "Contact",
                "item": "https://kairosweather.info/Static/Contact"
            }
        ]
    }
    </script>
    
    <!-- LocalBusiness Schema -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "LocalBusiness",
        "name": "Kairos Weather",
        "description": "Providing accurate and reliable weather information worldwide through our online weather service.",
        "url": "https://kairosweather.info",
        "telephone": "+1-XXX-XXX-XXXX",
        "email": "contact@kairosweather.info",
        "priceRange": "Free",
        "openingHoursSpecification": [
            {
                "@@type": "OpeningHoursSpecification",
                "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
                "opens": "00:00",
                "closes": "23:59"
            }
        ],
        "aggregateRating": {
            "@@type": "AggregateRating",
            "ratingValue": "4.8",
            "reviewCount": "1250",
            "bestRating": "5",
            "worstRating": "1"
        },
        "sameAs": [
            "https://twitter.com/KairosWeather",
            "https://facebook.com/KairosWeather",
            "https://linkedin.com/company/kairosweather"
        ],
        "address": {
            "@@type": "PostalAddress",
            "addressCountry": "IN"
        },
        "geo": {
            "@@type": "GeoCoordinates",
            "latitude": "20.5937",
            "longitude": "78.9629"
        }
    }
    </script>
    
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "Organization",
        "name": "Kairos Weather",
        "url": "https://kairosweather.info",
        "logo": "https://kairosweather.info/assets/logo.png",
        "description": "Providing accurate and reliable weather information worldwide.",
        "sameAs": [
            "https://twitter.com/KairosWeather",
            "https://facebook.com/KairosWeather",
            "https://linkedin.com/company/kairosweather"
        ],
        "contactPoint": {
            "@@type": "ContactPoint",
            "contactType": "customer service",
            "email": "contact@kairosweather.info",
            "availableLanguage": "English"
        }
    }
    </script>
</head>
<body>
    <div class="page-container">
        <header>
            <!-- Top Ad Unit -->
            <div class="ad-container ad-top">
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-3262579139378205"
                     data-ad-slot="5641058694"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
            </div>
            
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
                <div class="container">
                    <a class="navbar-brand fw-bold text-primary kairos-logo" href="/">
                        <span class="kairos-logo"><span style="color:blueviolet">Kairos Weather</span></span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                        <ul class="navbar-nav">
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Static" asp-action="About">About</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Static" asp-action="FAQ">FAQ</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Static" asp-action="Contact">Contact</a></li>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Admin
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminDropdown">
                                        <li><a class="dropdown-item" href="/admin/dashboard">Dashboard</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item text-danger" href="/admin/logout">Logout</a></li>
                                    </ul>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container content-wrap">
            <!-- Content Ad Unit -->
            <div class="ad-container ad-content">
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-3262579139378205"
                     data-ad-slot="5641058694"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
            </div>
            
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted site-footer">
            <!-- Footer Ad Unit -->
            <div class="ad-container ad-footer">
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-3262579139378205"
                     data-ad-slot="5641058694"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
            </div>
            
            <div class="container">
                <div class="footer-content">
                    <div class="footer-section">
                        <h4>Kairos Weather</h4>
                        <p>Accurate weather information for locations worldwide.</p>
                    </div>
                    <div class="footer-section">
                        <h4>Quick Links</h4>
                        <ul>
                            <li><a href="/">Home</a></li>
                            <li><a href="/Static/About">About</a></li>
                            <li><a href="/Static/FAQ">FAQ</a></li>
                            <li><a href="/Static/Contact">Contact</a></li>
                        </ul>
                    </div>
                    <div class="footer-section">
                        <h4>Legal</h4>
                        <ul>
                            <li><a href="/Static/PrivacyPolicy">Privacy Policy</a></li>
                            <li><a href="/Static/Terms">Terms of Service</a></li>
                            <li><a href="/Static/PrivacyPolicy#cookies">Cookie Policy</a></li>
                            <li><a href="/Static/AdDisclosure">Ad Disclosure</a></li>
                        </ul>
                    </div>
                </div>
                <div class="footer-bottom">
                    &copy; 2025 Kairos Weather. All rights reserved.
                </div>
            </div>
        </footer>
        
        <!-- Cookie Consent Banner -->
        <div id="cookie-consent" class="cookie-consent-banner">
            <div class="cookie-consent-content">
                <p>We use cookies to enhance your experience, analyze traffic, and serve personalized ads. By continuing to use this site, you consent to our use of cookies. <a href="/Static/PrivacyPolicy#cookies" target="_blank">Learn more</a></p>
                <div class="cookie-buttons">
                    <button id="accept-cookies" class="btn btn-primary">Accept</button>
                    <button id="decline-cookies" class="btn btn-secondary">Decline</button>
                </div>
            </div>
        </div>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </div>
  
</body>
</html>
