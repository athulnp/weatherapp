    <!-- Search Action Schema -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "WebSite",
      "url": "https://kairosweather.info",
      "potentialAction": {
        "@@type": "SearchAction",
        "target": {
          "@@type": "EntryPoint",
          "urlTemplate": "https://kairosweather.info/?search={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    @{
        // ---- Centralised SEO values (single source of truth) ----
        const string siteName = "Kairos Weather";
        const string baseUrl = "https://kairosweather.info";
        const string defaultDescription = "Get accurate live weather updates, temperature, humidity, wind speed, and forecasts for any city worldwide. Real-time weather data with a clean, fast, user-friendly interface.";
        const string defaultKeywords = "weather, forecast, live weather, temperature, humidity, wind speed, weather app, real-time weather, global weather, weather conditions, climate data";
        const string defaultOgImage = baseUrl + "/assets/og-image.png";

        var seoTitle = (ViewData["Title"]?.ToString()) ?? siteName;
        var seoDescription = (ViewData["Description"]?.ToString()) ?? (ViewData["MetaDescription"]?.ToString()) ?? defaultDescription;
        var seoKeywords = (ViewData["Keywords"]?.ToString()) ?? (ViewData["MetaKeywords"]?.ToString()) ?? defaultKeywords;
        var seoImage = (ViewData["OgImage"]?.ToString()) ?? defaultOgImage;
        var seoType = (ViewData["OgType"]?.ToString()) ?? "website";
        var seoRobots = (ViewData["Robots"]?.ToString()) ?? "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";

        // Canonical: explicit value from the view wins; otherwise build from the
        // request path (without query string, so ?search= variants don't fork the URL).
        var canonicalUrl = (ViewData["Canonical"]?.ToString());
        if (string.IsNullOrEmpty(canonicalUrl))
        {
            canonicalUrl = baseUrl + Context.Request.Path.Value;
        }

        // ---- hreflang alternates ----
        // Derive the language-neutral path (strip any /hi, /ta, /ml prefix) so we
        // can build one URL per supported language. Views that set an explicit
        // canonical (city/article pages) opt out of hreflang because those pages
        // are not URL-localised.
        var rawPath = Context.Request.Path.Value ?? "/";
        var neutralPath = rawPath;
        foreach (var code in new[] { "/hi", "/ta", "/ml" })
        {
            if (rawPath.Equals(code, StringComparison.OrdinalIgnoreCase))
            {
                neutralPath = "/";
                break;
            }
            if (rawPath.StartsWith(code + "/", StringComparison.OrdinalIgnoreCase))
            {
                neutralPath = rawPath.Substring(code.Length);
                break;
            }
        }
        // Emit hreflang on pages that opt in (the URL-localised homepage) or on
        // any page that doesn't set an explicit canonical. City/article pages set
        // a canonical and are not URL-localised, so they stay out.
        var emitHreflang = string.Equals(ViewData["Hreflang"]?.ToString(), "home", StringComparison.Ordinal)
                           || string.IsNullOrEmpty(ViewData["Canonical"]?.ToString());
        var langAlternates = new (string Hreflang, string Url)[]
        {
            ("en", baseUrl + neutralPath),
            ("hi", baseUrl + "/hi" + (neutralPath == "/" ? "" : neutralPath)),
            ("ta", baseUrl + "/ta" + (neutralPath == "/" ? "" : neutralPath)),
            ("ml", baseUrl + "/ml" + (neutralPath == "/" ? "" : neutralPath)),
            ("x-default", baseUrl + neutralPath)
        };
    }

    <!-- Primary Meta Tags -->
    <title>@seoTitle</title>
    <meta name="title" content="@seoTitle" />
    <meta name="description" content="@seoDescription" />
    <meta name="keywords" content="@seoKeywords" />
    <meta name="author" content="Kairos Weather" />
    <meta name="robots" content="@seoRobots" />
    <meta name="theme-color" content="#667eea" />
    <meta name="content-language" content="@htmlLang" />

    <!-- Canonical URL (single, authoritative) -->
    <link rel="canonical" href="@canonicalUrl" />

    <!-- hreflang alternates: one crawlable URL per supported language -->
    @if (emitHreflang)
    {
        foreach (var alt in langAlternates)
        {
            <link rel="alternate" hreflang="@alt.Hreflang" href="@alt.Url" />
        }
    }

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="@seoType" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:title" content="@seoTitle" />
    <meta property="og:description" content="@seoDescription" />
    <meta property="og:image" content="@seoImage" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Kairos Weather - Live Weather Updates" />
    <meta property="og:site_name" content="@siteName" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="@canonicalUrl" />
    <meta name="twitter:title" content="@seoTitle" />
    <meta name="twitter:description" content="@seoDescription" />
    <meta name="twitter:image" content="@seoImage" />
    <meta name="twitter:site" content="@@KairosWeather" />
    <meta name="twitter:creator" content="@@KairosWeather" />

