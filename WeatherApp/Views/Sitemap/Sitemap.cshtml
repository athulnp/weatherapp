@model IEnumerable<WeatherApp.Models.Article>
@{ Layout = null; }
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
        http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">

    <!-- Homepage (with language alternates) -->
    <url>
        <loc>https://kairosweather.info/</loc>
        <xhtml:link rel="alternate" hreflang="en" href="https://kairosweather.info/" />
        <xhtml:link rel="alternate" hreflang="hi" href="https://kairosweather.info/hi" />
        <xhtml:link rel="alternate" hreflang="ta" href="https://kairosweather.info/ta" />
        <xhtml:link rel="alternate" hreflang="ml" href="https://kairosweather.info/ml" />
        <xhtml:link rel="alternate" hreflang="x-default" href="https://kairosweather.info/" />
        <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>

    <!-- Localized homepages -->
    @foreach (var lang in new[] { "hi", "ta", "ml" })
    {
        <url>
            <loc>https://kairosweather.info/@lang</loc>
            <xhtml:link rel="alternate" hreflang="en" href="https://kairosweather.info/" />
            <xhtml:link rel="alternate" hreflang="hi" href="https://kairosweather.info/hi" />
            <xhtml:link rel="alternate" hreflang="ta" href="https://kairosweather.info/ta" />
            <xhtml:link rel="alternate" hreflang="ml" href="https://kairosweather.info/ml" />
            <xhtml:link rel="alternate" hreflang="x-default" href="https://kairosweather.info/" />
            <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
            <changefreq>daily</changefreq>
            <priority>0.9</priority>
        </url>
    }
    
    <!-- Blog Index -->
    <url>
        <loc>https://kairosweather.info/blog</loc>
        <lastmod>@(Model != null && Model.Any() ? Model.Max(a => a.PublishDate).ToString("yyyy-MM-dd") : DateTime.UtcNow.ToString("yyyy-MM-dd"))</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>

    <!-- Blog Articles -->
    @if (Model != null)
    {
        foreach (var article in Model)
        {
            <url>
                <loc>https://kairosweather.info/Article/@article.Slug</loc>
                <lastmod>@article.PublishDate.ToString("yyyy-MM-dd")</lastmod>
                <changefreq>monthly</changefreq>
                <priority>0.8</priority>
            </url>
        }
    }

    <!-- About Page -->
    <url>
        <loc>https://kairosweather.info/Static/About</loc>
        <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    
    <!-- FAQ Page -->
    <url>
        <loc>https://kairosweather.info/Static/FAQ</loc>
        <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    
    <!-- Contact Page -->
    <url>
        <loc>https://kairosweather.info/Static/Contact</loc>
        <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    
    <!-- Privacy Policy -->
    <url>
        <loc>https://kairosweather.info/Static/PrivacyPolicy</loc>
        <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.5</priority>
    </url>
    
    <!-- Terms of Service -->
    <url>
        <loc>https://kairosweather.info/Static/Terms</loc>
        <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.5</priority>
    </url>
    
    <!-- Ad Disclosure -->
    <url>
        <loc>https://kairosweather.info/Static/AdDisclosure</loc>
        <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.3</priority>
    </url>

    <!-- Popular City Weather Pages -->
    @foreach (var city in WeatherApp.Data.PopularCities.Slugs)
    {
        <url>
            <loc>https://kairosweather.info/weather/@city</loc>
            <lastmod>@DateTime.UtcNow.ToString("yyyy-MM-dd")</lastmod>
            <changefreq>daily</changefreq>
            <priority>0.7</priority>
        </url>
    }

</urlset>
