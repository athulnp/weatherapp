
@{
    ViewData["Title"] = "About Us";
    ViewData["MetaDescription"] = "Learn about Kairos Weather - your reliable source for accurate, real-time weather information worldwide. Our mission, technology, and commitment to quality.";
    ViewData["MetaKeywords"] = "Kairos Weather about, weather service mission, weather technology, weather accuracy, global weather coverage";
}

@section Head {
    <meta name="description" content="@ViewData["MetaDescription"]" />
    <meta name="keywords" content="@ViewData["MetaKeywords"]" />
}

<!-- Article Structured Data -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "Article",
    "headline": "About Kairos Weather - Your Reliable Weather Information Source",
    "description": "Learn about Kairos Weather's mission, technology, and commitment to providing accurate weather information worldwide.",
    "image": "https://kairosweather.info/assets/logo.png",
    "author": {
        "@@type": "Organization",
        "name": "Kairos Weather",
        "url": "https://kairosweather.info"
    },
    "publisher": {
        "@@type": "Organization",
        "name": "Kairos Weather",
        "logo": {
            "@@type": "ImageObject",
            "url": "https://kairosweather.info/assets/logo.png",
            "width": 512,
            "height": 512
        }
    },
    "datePublished": "2025-01-01",
    "dateModified": "2025-01-15",
    "mainEntityOfPage": {
        "@@type": "WebPage",
        "@@id": "https://kairosweather.info/Static/About"
    }
}
</script>

<div class="container content-page">
    <h1 data-i18n="AboutPageTitle">About Kairos Weather</h1>
    <p class="last-updated" data-i18n="LastUpdated">Last Updated: January 2025</p>
    
    <p data-i18n="AboutPageWelcome">Welcome to <strong>Kairos Weather</strong> — your reliable source for accurate, real-time weather information worldwide. We are dedicated to providing you with the weather data you need to plan your day, stay safe, and make informed decisions.</p>
    
    <h2 data-i18n="OurMission">Our Mission</h2>
    <p data-i18n="OurMissionDesc">At Kairos Weather, our mission is simple: to make weather information accessible, accurate, and easy to understand for everyone. We believe that weather plays a crucial role in daily life — from planning outdoor activities to ensuring safety during severe weather conditions.</p>
    
    <h2 data-i18n="WhatWeOffer">What We Offer</h2>
    <p data-i18n="WhatWeOfferDesc">Kairos Weather provides comprehensive weather services designed to meet your needs:</p>
    <ul>
        <li><strong data-i18n="RealTimeWeatherData">Real-Time Weather Data:</strong> <span data-i18n="RealTimeWeatherDataDesc">Current weather conditions including temperature, humidity, wind speed, and more</span></li>
        <li><strong data-i18n="GlobalCoverage">Global Coverage:</strong> <span data-i18n="GlobalCoverageDesc2">Weather information for cities and locations worldwide</span></li>
        <li><strong data-i18n="MultipleSearchOptions">Multiple Search Options:</strong> <span data-i18n="MultipleSearchOptionsDesc">Search by city name, postal code, or GPS coordinates</span></li>
        <li><strong data-i18n="UserFriendlyInterface">User-Friendly Interface:</strong> <span data-i18n="UserFriendlyInterfaceDesc">Clean, modern design that works seamlessly on all devices</span></li>
        <li><strong data-i18n="AccurateForecasts">Accurate Forecasts:</strong> <span data-i18n="AccurateForecastsDesc">Reliable data sourced from trusted weather APIs</span></li>
    </ul>
    
    <h2 data-i18n="OurTechnology">Our Technology</h2>
    <p data-i18n="OurTechnologyDesc">We leverage cutting-edge technology and partnerships with leading weather data providers to ensure the accuracy and reliability of our information. Our platform is built using modern web technologies to deliver fast, responsive, and accessible weather information.</p>
    
    <h2 data-i18n="CommitmentToQuality">Commitment to Quality</h2>
    <p data-i18n="CommitmentToQualityDesc">We are committed to continuously improving our services. Our team works tirelessly to:</p>
    <ul>
        <li data-i18n="Quality1">Enhance data accuracy and update frequency</li>
        <li data-i18n="Quality2">Improve user experience across all devices</li>
        <li data-i18n="Quality3">Add new features based on user feedback</li>
        <li data-i18n="Quality4">Maintain high standards of data privacy and security</li>
        <li data-i18n="Quality5">Provide excellent customer support</li>
    </ul>
    
    <h2 data-i18n="OurValues">Our Values</h2>
    <ul>
        <li><strong data-i18n="ValueAccuracy">Accuracy:</strong> <span data-i18n="ValueAccuracyDesc">We prioritize data accuracy and reliability above all else</span></li>
        <li><strong data-i18n="ValueAccessibility">Accessibility:</strong> <span data-i18n="ValueAccessibilityDesc">Weather information should be accessible to everyone, everywhere</span></li>
        <li><strong data-i18n="ValueTransparency">Transparency:</strong> <span data-i18n="ValueTransparencyDesc">We are open about our data sources and how we use your information</span></li>
        <li><strong data-i18n="ValueUserCentric">User-Centric:</strong> <span data-i18n="ValueUserCentricDesc">Your needs and feedback drive our improvements</span></li>
        <li><strong data-i18n="ValueInnovation">Innovation:</strong> <span data-i18n="ValueInnovationDesc">We constantly explore new ways to enhance our services</span></li>
    </ul>
    
    <h2 data-i18n="PrivacySecurity">Privacy & Security</h2>
    <p data-i18n="PrivacySecurityDesc">We take your privacy seriously. Kairos Weather is committed to protecting your personal information and ensuring a secure browsing experience. Please review our <a href="/Static/PrivacyPolicy" data-i18n="PrivacyPolicy">Privacy Policy</a> to learn more about how we handle your data.</p>
    
    <h2 data-i18n="GetInTouch">Get in Touch</h2>
    <p data-i18n="GetInTouchDesc2">We value your feedback and are always looking for ways to improve. If you have questions, suggestions, or concerns, please don't hesitate to <a href="/Static/Contact" data-i18n="ContactUs">contact us</a>. Your input helps us serve you better.</p>
    
    <h2 data-i18n="ThankYou">Thank You</h2>
    <p data-i18n="ThankYouDesc">Thank you for choosing Kairos Weather as your trusted weather information source. We are honored to serve you and look forward to helping you stay informed about the weather conditions that matter to you.</p>
</div>