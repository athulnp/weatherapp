                                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                </svg>
                            </div>
                            <h3 class="feature-title" data-i18n="AccurateForecasts">Accurate Forecasts</h3>
                            <p class="feature-desc" data-i18n="AccurateForecastsDesc">Reliable data sourced from trusted weather APIs</p>
                        </div>
