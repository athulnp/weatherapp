@{
    ViewData["Title"] = "Contact Us";
}

<div class="container content-page">
    <h1>Contact Us</h1>
    <p>We value your feedback and are here to help. If you have any questions, suggestions, or concerns about Kairos Weather, please don't hesitate to reach out to us.</p>
    
    <div class="contact-section">
        <h2>Get in Touch</h2>
        <p>We strive to respond to all inquiries within 24-48 hours during business days.</p>
        
        <h3>Email</h3>
        <p><strong>Primary Email:</strong> <a href="mailto:contact@kairosweather.info">contact@kairosweather.info</a></p>
        <p><strong>Support Email:</strong> <a href="mailto:support@kairosweather.info">support@kairosweather.info</a></p>
        
        <h3>Business Hours</h3>
        <p>Monday - Friday: 9:00 AM - 6:00 PM (UTC)</p>
        <p>Saturday - Sunday: Closed</p>
        
        <h3>Response Time</h3>
        <p>We typically respond to inquiries within 1-2 business days. For urgent matters, please include "URGENT" in your subject line.</p>
        
        <h3>What We Can Help With</h3>
        <ul>
            <li>Technical issues and bug reports</li>
            <li>Feature requests and suggestions</li>
            <li>Privacy policy questions</li>
            <li>Data removal requests</li>
            <li>Business inquiries and partnerships</li>
            <li>Advertising opportunities</li>
            <li>General feedback and comments</li>
        </ul>
        
        <h3>Before Contacting Us</h3>
        <p>Please check our <a href="/Static/FAQ">FAQ</a> section for quick answers to common questions. Many inquiries can be resolved by reviewing our documentation.</p>
        
        <h3>Privacy & Data</h3>
        <p>For questions about your personal data or to exercise your privacy rights, please review our <a href="/Static/PrivacyPolicy">Privacy Policy</a> or contact us directly.</p>
        
        <h3>Social Media</h3>
        <p>Follow us on social media for updates and weather tips:</p>
        <ul>
            <li><a href="https://twitter.com/KairosWeather" target="_blank" rel="noopener">Twitter: @@KairosWeather</a></li>
            <li><a href="https://facebook.com/KairosWeather" target="_blank" rel="noopener">Facebook: Kairos Weather</a></li>
        </ul>
    </div>
</div>

