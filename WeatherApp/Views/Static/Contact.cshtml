@{
    ViewData["Title"] = "Contact Us";
}

<div class="container content-page">
    <h1 data-i18n="ContactUsTitle">Contact Us</h1>
    <p data-i18n="ContactUsDesc">We value your feedback and are here to help. If you have any questions, suggestions, or concerns about Kairos Weather, please don't hesitate to reach out to us.</p>
    
    <div class="contact-section">
        <h2 data-i18n="GetInTouch">Get in Touch</h2>
        <p data-i18n="GetInTouchDesc">We strive to respond to all inquiries within 24-48 hours during business days.</p>
        
        <h3 data-i18n="Email">Email</h3>
        <p><strong data-i18n="PrimaryEmail">Primary Email:</strong> <a href="mailto:contact@kairosweather.info">contact@kairosweather.info</a></p>
        <p><strong data-i18n="SupportEmail">Support Email:</strong> <a href="mailto:support@kairosweather.info">support@kairosweather.info</a></p>
        
        <h3 data-i18n="BusinessHours">Business Hours</h3>
        <p data-i18n="BusinessHoursWeekdays">Monday - Friday: 9:00 AM - 6:00 PM (UTC)</p>
        <p data-i18n="BusinessHoursWeekend">Saturday - Sunday: Closed</p>
        
        <h3 data-i18n="ResponseTime">Response Time</h3>
        <p data-i18n="ResponseTimeDesc">We typically respond to inquiries within 1-2 business days. For urgent matters, please include "URGENT" in your subject line.</p>
        
        <h3 data-i18n="WhatWeCanHelpWith">What We Can Help With</h3>
        <ul>
            <li data-i18n="HelpTechnicalIssues">Technical issues and bug reports</li>
            <li data-i18n="HelpFeatureRequests">Feature requests and suggestions</li>
            <li data-i18n="HelpPrivacyQuestions">Privacy policy questions</li>
            <li data-i18n="HelpDataRemoval">Data removal requests</li>
            <li data-i18n="HelpBusinessInquiries">Business inquiries and partnerships</li>
            <li data-i18n="HelpAdvertising">Advertising opportunities</li>
            <li data-i18n="HelpFeedback">General feedback and comments</li>
        </ul>
        
        <h3 data-i18n="BeforeContactingUs">Before Contacting Us</h3>
        <p data-i18n="BeforeContactingUsDesc">Please check our <a href="/Static/FAQ" data-i18n="FAQ">FAQ</a> section for quick answers to common questions. Many inquiries can be resolved by reviewing our documentation.</p>
        
        <h3 data-i18n="PrivacyData">Privacy & Data</h3>
        <p data-i18n="PrivacyDataDesc">For questions about your personal data or to exercise your privacy rights, please review our <a href="/Static/PrivacyPolicy" data-i18n="PrivacyPolicy">Privacy Policy</a> or contact us directly.</p>
        
        <h3 data-i18n="SocialMedia">Social Media</h3>
        <p data-i18n="SocialMediaDesc">Follow us on social media for updates and weather tips:</p>
        <ul>
            <li><a href="https://twitter.com/KairosWeather" target="_blank" rel="noopener">Twitter: @@KairosWeather</a></li>
            <li><a href="https://facebook.com/KairosWeather" target="_blank" rel="noopener">Facebook: Kairos Weather</a></li>
        </ul>
    </div>
</div>

